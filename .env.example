# Copy to .env and fill in your keys
ANTHROPIC_API_KEY=your_anthropic_key_here
FRED_API_KEY=your_fred_api_key_here          # https://fred.stlouisfed.org/docs/api/api_key.html
LITELLM_MASTER_KEY=your_litellm_key_here     # any string, used to auth with local LiteLLM proxy

# Database path (default: ~/.invest-manager/invest.db)
DB_PATH=

# LiteLLM proxy URL (default: http://localhost:4000)
LITELLM_BASE_URL=http://localhost:4000

# Anomaly detection thresholds (optional overrides)
ZSCORE_THRESHOLD=2.5
VOLUME_SPIKE_RATIO=3.0
CRYPTO_SPREAD_PCT=1.5
AI_ESCALATION_SCORE=7.0

# Alert deduplication window in hours
ALERT_DEDUP_HOURS=4
